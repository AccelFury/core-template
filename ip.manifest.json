{
  "schema_version": "0.1.0",
  "ip": {
    "name": "af_mod_add",
    "vendor": "accelfury",
    "category": "field_arithmetic",
    "description": "Parametric modular addition IP core for ZK-friendly finite fields",
    "license": "CERN-OHL-S-2.0",
    "rtl_languages": [
      "verilog-2001",
      "verilog-2005",
      "systemverilog"
    ],
    "rtl_language": "systemverilog",
    "default_field": "goldilocks",
    "default_modulus_hex": "0xFFFFFFFF00000001"
  },
  "interfaces": [
    {
      "name": "stream_in",
      "type": "ready_valid",
      "payload_bits": 64,
      "signals": [
        "i_clk",
        "i_rst_n",
        "i_valid",
        "o_ready",
        "i_a",
        "i_b"
      ]
    },
    {
      "name": "stream_out",
      "type": "ready_valid",
      "payload_bits": 64,
      "signals": [
        "o_valid",
        "i_ready",
        "o_result"
      ]
    }
  ],
  "parameters": [
    {
      "name": "FIELD_BITS",
      "type": "int",
      "default": 64,
      "description": "Field width in bits"
    },
    {
      "name": "MODULUS",
      "type": "logic_vector",
      "default": "64'hFFFF_FFFF_0000_0001",
      "description": "Modulo prime"
    }
  ],
